{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {}
        },
        {
            "name": "ARMgcc",
            "hidden": true,
            "inherits": "default",
            "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake"
        },
        {
            "name": "ARMclang",
            "hidden": true,
            "inherits": "default",
            "toolchainFile": "${sourceDir}/cmake/starm-clang.cmake"
        },
        {
            "name": "HOSTgcc",
            "inherits": "default",
            "toolchainFile": "${sourceDir}/cmake/gcc.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "UNIT_TESTING": true
            }
        },
        {
            "name": "Debug",
            "inherits": "ARMgcc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Release",
            "inherits": "ARMgcc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        { "name": "Debug", "configurePreset": "Debug",
            "nativeToolOptions": [
                "-k", "0"
            ]
        },
        { "name": "Release", "configurePreset": "Release",
            "nativeToolOptions": [
                "-k", "0"
            ]
        },
        { "name": "Tests", "configurePreset": "HOSTgcc",
            "nativeToolOptions": [
                "-k", "0"
            ]
        }
    ],
    "testPresets": [
        {
            "name": "Tests",
            "configurePreset": "HOSTgcc",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
